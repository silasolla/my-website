---
import { getImage } from 'astro:assets';
import LanguageSwitch from './LanguageSwitch.astro';
import { getTranslation } from '../i18n/translations';
import { getSiteTitle } from '../i18n/utils';
import { profileData } from '../data/profile';
import avatarSrc from '../assets/avatar.png';

interface Props {
  mobileBg: Awaited<ReturnType<typeof getImage>>;
  tabletBg: Awaited<ReturnType<typeof getImage>>;
  desktopBg: Awaited<ReturnType<typeof getImage>>;
}

const siteTitle = getSiteTitle(Astro.currentLocale);
const tagline = getTranslation(Astro.currentLocale, 'site.tagline');
const themeToggleLabel = getTranslation(Astro.currentLocale, 'theme.toggle');
const themeToggleTitle = getTranslation(Astro.currentLocale, 'theme.dark-light');

const { mobileBg, tabletBg, desktopBg } = Astro.props;
const avatar = await getImage({
  src: avatarSrc,
  width: 120,
  height: 120,
  format: 'webp',
  quality: 75,
});
---

<header
  class="header"
  id="header"
  style={`--bgMobile: url(${mobileBg.src}); --bgTablet: url(${tabletBg.src}); --bgDesktop: url(${desktopBg.src});`}
>
  <div class="header-bg-overlay"></div>
  <div class="header-content">
    <a href="/" class="site-title">
      <img
        src={avatar.src}
        alt={profileData.nameEn}
        width={avatar.attributes.width}
        height={avatar.attributes.height}
        loading="eager"
        decoding="async"
        class="avatar"
      />
      <div class="title-text">
        <h1>{siteTitle}</h1>
        <p class="tagline">{tagline}</p>
      </div>
    </a>
    <div class="header-controls">
      <LanguageSwitch />
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label={themeToggleLabel}
        title={themeToggleTitle}
      >
        <svg
          class="sun-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="moon-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>
