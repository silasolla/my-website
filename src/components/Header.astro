---
import { getImage } from 'astro:assets';
import LanguageSwitch from './LanguageSwitch.astro';
import { getTranslation } from '../i18n/translations';
import { getSiteTitle } from '../i18n/utils';
import { profileData } from '../data/profile';
import avatarSrc from '../assets/avatar.png';

interface Props {
  mobileBg: Awaited<ReturnType<typeof getImage>>;
  tabletBg: Awaited<ReturnType<typeof getImage>>;
  desktopBg: Awaited<ReturnType<typeof getImage>>;
}

const siteTitle = getSiteTitle(Astro.currentLocale);
const tagline = getTranslation(Astro.currentLocale, 'site.tagline');
const themeToggleLabel = getTranslation(Astro.currentLocale, 'theme.toggle');
const themeToggleTitle = getTranslation(Astro.currentLocale, 'theme.dark-light');

const { mobileBg, tabletBg, desktopBg } = Astro.props;
const avatar = await getImage({
  src: avatarSrc,
  width: 120,
  height: 120,
  format: 'webp',
  quality: 75,
});
---

<header
  class="header"
  id="header"
  style={`--bgMobile: url(${mobileBg.src}); --bgTablet: url(${tabletBg.src}); --bgDesktop: url(${desktopBg.src});`}
>
  <div class="header-bg-overlay"></div>
  <div class="header-content">
    <a href="/" class="site-title">
      <img
        src={avatar.src}
        alt={profileData.nameEn}
        width={avatar.attributes.width}
        height={avatar.attributes.height}
        loading="eager"
        decoding="async"
        class="avatar"
      />
      <div class="title-text">
        <h1>{siteTitle}</h1>
        <p class="tagline">{tagline}</p>
      </div>
    </a>
    <div class="header-controls">
      <LanguageSwitch />
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label={themeToggleLabel}
        title={themeToggleTitle}
      >
        <svg
          class="sun-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="moon-icon"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: relative;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--color-header-text);
    padding: 2rem 0;
    margin-bottom: 2rem;
    box-shadow: 0 2px 8px var(--color-header-shadow);
    transition: background 0.3s ease;
  }

  @media (max-width: 768px) {
    .header {
      background-image: var(--bgMobile);
    }
  }

  @media (min-width: 769px) and (max-width: 1440px) {
    .header {
      background-image: var(--bgTablet);
    }
  }

  @media (min-width: 1441px) {
    .header {
      background-image: var(--bgDesktop);
    }
  }

  .header-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-header-overlay);
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme='dark']) .header {
    box-shadow: 0 2px 12px var(--color-header-shadow);
  }

  .header-content {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    flex: 1;
  }

  .avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-header-avatar-border);
    box-shadow: 0 2px 8px var(--color-header-avatar-shadow);
  }

  .title-text h1 {
    margin: 0;
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-header-text);
  }

  .tagline {
    margin: 0.5rem 0 0 0;
    font-size: 1.1rem;
    opacity: 0.88;
    font-style: italic;
    color: var(--color-header-text-muted);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .theme-toggle {
    background: var(--color-header-control-bg);
    border: 2px solid var(--color-header-control-border);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    background: var(--color-header-control-bg-hover);
    border-color: var(--color-header-control-border-hover);
    transform: rotate(180deg);
  }

  .theme-toggle svg {
    width: 24px;
    height: 24px;
    color: var(--color-header-text);
  }

  .sun-icon {
    display: none;
  }

  .moon-icon {
    display: block;
  }

  :global([data-theme='dark']) .sun-icon {
    display: block;
  }

  :global([data-theme='dark']) .moon-icon {
    display: none;
  }

  @media (max-width: 1200px) {
    .header-content {
      padding: 0 2rem;
    }
  }

  @media (max-width: 640px) {
    .header {
      padding: 1.5rem 0;
    }

    .header-content {
      flex-direction: column;
      align-items: center;
      padding: 0 1rem;
    }

    .site-title {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }

    .avatar {
      width: 80px;
      height: 80px;
    }

    .title-text h1 {
      font-size: 1.6rem;
    }

    .tagline {
      font-size: 1rem;
    }

    .theme-toggle {
      width: 48px;
      height: 48px;
    }
  }
</style>
