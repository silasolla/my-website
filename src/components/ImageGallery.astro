---
import { getTranslation } from '../i18n/translations';
import '../styles/image-gallery.css';

interface Props {
  images: string[];
  alt: string;
}

const { images, alt } = Astro.props;
const imageLabel = getTranslation(Astro.currentLocale, 'gallery.image');

const getRightSideCount = (totalImages: number): number => {
  if (totalImages <= 2) return 0;
  return Math.min(6, Math.ceil((totalImages - 1) / 2));
};

const getLeftSideCount = (totalImages: number): number => {
  if (totalImages <= 2) return 0;
  return Math.min(6, Math.floor((totalImages - 1) / 2));
};

const rightSideCount = getRightSideCount(images.length);
const leftSideCount = getLeftSideCount(images.length);
---

<div class="image-gallery" data-images={JSON.stringify(images)}>
  <div class="gallery-container">
    {
      leftSideCount > 0 && (
        <div class="side-images left-side" style={`--columns: ${Math.ceil(leftSideCount / 2)}`}>
          {Array.from({ length: leftSideCount }).map((_, i) => (
            <img
              src={images[1 + rightSideCount + i]}
              alt={alt}
              class="side-img"
              data-side-index={i}
            />
          ))}
        </div>
      )
    }

    <div class="main-image-container">
      <img src={images[0]} alt={alt} class="main-image" />
    </div>

    {
      rightSideCount > 0 && (
        <div class="side-images right-side" style={`--columns: ${Math.ceil(rightSideCount / 2)}`}>
          {Array.from({ length: rightSideCount }).map((_, i) => (
            <img src={images[1 + i]} alt={alt} class="side-img" data-side-index={i} />
          ))}
        </div>
      )
    }
  </div>

  {
    images.length > 1 && (
      <div class="dots-nav">
        {images.map((_, index) => (
          <button
            type="button"
            class={`dot ${index === 0 ? 'active' : ''}`}
            data-index={index}
            aria-label={`${imageLabel} ${index + 1}`}
          />
        ))}
      </div>
    )
  }
</div>

<script>
  document.querySelectorAll('.image-gallery:not([data-ready])').forEach((galleryElement) => {
    galleryElement.setAttribute('data-ready', '');

    const imagesData = galleryElement.getAttribute('data-images');
    const images: string[] = imagesData ? JSON.parse(imagesData) : [];
    if (images.length === 0) return;

    let currentIndex = 0;
    const mainImageOrNull = galleryElement.querySelector<HTMLImageElement>('.main-image');
    if (!mainImageOrNull) return;
    const mainImage: HTMLImageElement = mainImageOrNull;
    const leftSideImages = galleryElement.querySelectorAll('.left-side .side-img');
    const rightSideImages = galleryElement.querySelectorAll('.right-side .side-img');
    const dots = galleryElement.querySelectorAll('.dot');

    function updateImage(index: number): void {
      currentIndex = index;
      mainImage.src = images[index];

      rightSideImages.forEach((img, i) => {
        if (img instanceof HTMLImageElement) {
          const targetIndex = (index + 1 + i) % images.length;
          img.src = images[targetIndex];
        }
      });

      leftSideImages.forEach((img, i) => {
        if (img instanceof HTMLImageElement) {
          const targetIndex = (index + 1 + rightSideImages.length + i) % images.length;
          img.src = images[targetIndex];
        }
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });

      const activeDot = dots[index];
      if (activeDot instanceof HTMLElement) {
        requestAnimationFrame(() => {
          activeDot.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'center',
          });
        });
      }
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index') || '0', 10);
        updateImage(index);
      });
    });

    rightSideImages.forEach((img, i) => {
      img.addEventListener('click', () => {
        const newIndex = (currentIndex + 1 + i) % images.length;
        updateImage(newIndex);
      });
    });

    leftSideImages.forEach((img, i) => {
      img.addEventListener('click', () => {
        const newIndex = (currentIndex + 1 + rightSideImages.length + i) % images.length;
        updateImage(newIndex);
      });
    });

    let startX = 0;
    let currentX = 0;
    let isDragging = false;
    let hasMoved = false;
    const swipeThreshold = 60;
    const minMoveDistance = 5;

    function handleSwipeEnd(diff: number): void {
      mainImage.style.transition = 'opacity 0.2s ease';
      mainImage.style.opacity = '1';

      if (Math.abs(diff) > swipeThreshold && hasMoved) {
        if (diff < 0) {
          const newIndex = (currentIndex + 1) % images.length;
          setTimeout(() => updateImage(newIndex), 150);
        } else {
          const newIndex = (currentIndex - 1 + images.length) % images.length;
          setTimeout(() => updateImage(newIndex), 150);
        }
      }
    }

    mainImage.addEventListener(
      'touchstart',
      (e) => {
        startX = e.changedTouches[0].clientX;
        currentX = startX;
        hasMoved = false;
      },
      { passive: true }
    );

    mainImage.addEventListener(
      'touchmove',
      (e) => {
        if (!startX) return;
        currentX = e.changedTouches[0].clientX;
        const diff = currentX - startX;

        if (Math.abs(diff) > minMoveDistance) {
          hasMoved = true;
        }

        if (hasMoved) {
          const opacity = Math.max(0.7, 1 - Math.abs(diff) / 300);
          mainImage.style.opacity = opacity.toString();
          mainImage.style.transition = 'none';
        }
      },
      { passive: true }
    );

    mainImage.addEventListener(
      'touchend',
      () => {
        const diff = currentX - startX;
        handleSwipeEnd(diff);
        startX = 0;
        currentX = 0;
        hasMoved = false;
      },
      { passive: true }
    );

    mainImage.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      currentX = startX;
      hasMoved = false;
      mainImage.style.cursor = 'grabbing';
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      currentX = e.clientX;
      const diff = currentX - startX;

      if (Math.abs(diff) > minMoveDistance) {
        hasMoved = true;
      }

      if (hasMoved) {
        const opacity = Math.max(0.7, 1 - Math.abs(diff) / 300);
        mainImage.style.opacity = opacity.toString();
        mainImage.style.transition = 'none';
      }
    });

    document.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      const diff = currentX - startX;
      handleSwipeEnd(diff);
      mainImage.style.cursor = 'grab';
      startX = 0;
      currentX = 0;
      hasMoved = false;
    });

    mainImage.style.cursor = 'grab';
  });
</script>
