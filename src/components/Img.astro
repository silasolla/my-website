---
/**
 * 画像コンポーネント - @@/ 記法とキャプションをサポート
 *
 * Usage:
 *   import Img from '@/components/Img.astro';
 *   <Img src="@@/2025-10-26-03_test/image.webp" alt="説明" caption="図1: 実行結果" width="400" />
 */

import { resolveImageUrl } from '../utils/image';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: string | number;
  height?: string | number;
  class?: string;
}

const { src, alt, caption, width, height, class: className } = Astro.props;

const resolvedSrc = resolveImageUrl(src) || src;
---

{
  caption ? (
    <figure class={className}>
      <img
        src={resolvedSrc}
        alt={alt}
        width={width}
        height={height}
        loading="lazy"
        decoding="async"
      />
      <figcaption>{caption}</figcaption>
    </figure>
  ) : (
    <img
      src={resolvedSrc}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading="lazy"
      decoding="async"
    />
  )
}
