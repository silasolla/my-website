---
import type { TalkItem } from '../data/about';
import { getTranslation } from '../i18n/translations';
import { postsBasePath } from '../utils/paths';

interface Props {
  items: TalkItem[];
}

const { items } = Astro.props;
const detailsText = getTranslation(Astro.currentLocale, 'component.details');
const eventLabel = getTranslation(Astro.currentLocale, 'talks.event');
const slidesLabel = getTranslation(Astro.currentLocale, 'talks.slides');
const postLabel = getTranslation(Astro.currentLocale, 'talks.post');
const postsBase = `${postsBasePath(Astro.currentLocale)}/`;
---

<div class="talk-grid">
  {
    items.map((item) => (
      <article class="talk-card">
        <div class="talk-card-header">
          <span class="talk-date">{item.date}</span>
          <h4 class="talk-title">{item.title}</h4>
          <p class="talk-event">{item.event}</p>
        </div>

        {item.description && (
          <details class="talk-details">
            <summary class="talk-summary">{detailsText}</summary>
            <p class="talk-description">{item.description}</p>
          </details>
        )}

        <div class="talk-links">
          {item.postSlug && (
            <a href={`${postsBase}${item.postSlug}/`} class="talk-link">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
              </svg>
              {postLabel}
            </a>
          )}
          {item.slideUrl && (
            <a href={item.slideUrl} target="_blank" rel="noopener noreferrer" class="talk-link">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              {slidesLabel}
            </a>
          )}
          {item.eventUrl && (
            <a href={item.eventUrl} target="_blank" rel="noopener noreferrer" class="talk-link">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              {eventLabel}
            </a>
          )}
        </div>
      </article>
    ))
  }
</div>
