---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getCurrentLocale, getTranslation } from '../i18n/translations';
import { getSiteTitle, getSiteDescription } from '../i18n/utils';
import { profileData, seoKeywords } from '../data/profile';
import { themeColor } from '../data/theme.mjs';
import DevImageFallbackScript from '../components/DevImageFallbackScript.astro';
import { getHeaderBackgrounds } from '../lib/headerBackgrounds';

// Global styles
import '../styles/global.css';
import '../styles/link-card.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  math?: boolean;
}

const locale = getCurrentLocale(Astro.currentLocale);
const siteTitle = getSiteTitle(Astro.currentLocale);
const defaultDescription = getSiteDescription(Astro.currentLocale);

const {
  title,
  description = defaultDescription,
  image,
  noIndex = false,
  math = false,
} = Astro.props;

const { mobileBg, tabletBg, desktopBg } = await getHeaderBackgrounds();

// 開発環境でのフォールバック用
const isDev = import.meta.env.DEV;
const imageBaseUrl = import.meta.env.IMAGE_BASE_URL || '';

// OGP用の絶対URL
const siteUrl = import.meta.env.SITE_URL || Astro.site?.toString() || 'http://localhost:4321';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image ? new URL(image, siteUrl).href : `${siteUrl}/avatar.png`;

// 構造化データ（JSON-LD）
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profileData.name,
  alternateName: profileData.alternateNames,
  url: siteUrl,
  image: `${siteUrl}${profileData.avatar}`,
  jobTitle: profileData.jobTitle,
  description: profileData.description,
  sameAs: Object.values(profileData.social).filter(Boolean),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content={`${profileData.nameEn} (${profileData.username})`} />

    {/* Robots meta tag (特別記事用) */}
    {
      noIndex && (
        <>
          <meta name="robots" content="noindex, nofollow, noarchive" />
          <meta name="googlebot" content="noindex, nofollow" />
        </>
      )
    }

    {/* Favicons */}
    {/* Apple Touch Icons (iOS Safari) */}
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon-120x120.png" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon.png" />
    {/* Standard favicons */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    {/* Android/Chrome */}
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    {!isDev && <link rel="manifest" href="/site.webmanifest" />}
    <meta name="theme-color" content={themeColor} />

    <link
      rel="preload"
      as="image"
      href={mobileBg.src}
      media="(max-width: 768px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={tabletBg.src}
      media="(min-width: 769px) and (max-width: 1440px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={desktopBg.src}
      media="(min-width: 1441px)"
      fetchpriority="high"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* Canonical URL */}
    <link rel="canonical" href={currentUrl} />

    {/* RSS Feeds */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle + ' - ' + getTranslation(Astro.currentLocale, 'rss.feed-title-suffix')}
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle + ' - ' + getTranslation(Astro.currentLocale, 'rss.feed-title-news-suffix')}
      href="/rss/news.xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle + ' - ' + getTranslation(Astro.currentLocale, 'rss.feed-title-tech-suffix')}
      href="/rss/tech.xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle + ' - ' + getTranslation(Astro.currentLocale, 'rss.feed-title-diary-suffix')}
      href="/rss/diary.xml"
    />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={`@${profileData.username}`} />
    <meta name="twitter:creator" content={`@${profileData.username}`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Keywords for search */}
    <meta name="keywords" content={seoKeywords.join(',')} />

    {/* Structured Data (JSON-LD) for Person */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    {/* Theme initialization script (runs before page renders to prevent flash) */}
    <script is:inline>
      const getThemePreference = () => {
        const stored = localStorage.getItem('theme');
        if (stored) return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const theme = getThemePreference();
      document.documentElement.setAttribute('data-theme', theme);

      window.addEventListener('DOMContentLoaded', () => {
        const toggleButton = document.getElementById('theme-toggle');
        if (toggleButton) {
          toggleButton.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
          });
        }
      });
    </script>

    {/* 開発環境での画像フォールバック */}
    {isDev && <DevImageFallbackScript />}

    {math && <link rel="stylesheet" href="/vendor/katex.min.css" />}
  </head>
  <body {...isDev ? { 'data-dev': 'true', 'data-image-base': imageBaseUrl } : {}}>
    <Header mobileBg={mobileBg} tabletBg={tabletBg} desktopBg={desktopBg} />
    <main class="main-content">
      <div class="container">
        <Navigation />
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
