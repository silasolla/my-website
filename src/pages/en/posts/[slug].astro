---
import { getCollection } from 'astro:content';
import PostArticle from '../../../layouts/PostArticle.astro';
import { resolveImageUrl } from '../../../utils/image';
import { hasMathContent } from '../../../utils/math';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  return allPosts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const coverImage = resolveImageUrl(entry.data.coverImage);
const math = hasMathContent(entry.body ?? '');
---

<PostArticle entry={entry} coverImage={coverImage} math={math} />
