---
import IdentitySignedPage from '../../../../../layouts/IdentitySignedPage.astro';
import { profileData } from '../../../../../data/profile';

export function getStaticPaths() {
  const proofs = profileData.identityProofs || [];

  return proofs.map((proof) => ({
    params: {
      platform: proof.platform,
      account: proof.account,
    },
  }));
}

const { platform, account } = Astro.params;
---

<IdentitySignedPage platform={platform!} account={account!} />
