---
import { getCollection } from 'astro:content';
import PostsIndex from '../../layouts/PostsIndex.astro';
import { sortPosts } from '../../utils/posts';

const allPosts = await getCollection('posts', (post) => {
  return post.data.lang === 'ja' || post.data.lang === undefined;
});
const sortedPosts = sortPosts(allPosts);
---

<PostsIndex posts={sortedPosts} />
